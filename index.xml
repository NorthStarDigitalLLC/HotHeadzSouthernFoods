<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Hot Headz Southern Foods</title>
  <meta name="description" content="Hot Headz Southern Foods serves home-style Southern cooking in DeRidder, Louisiana. Breakfast, lunch, carry-out, dine-in, and delivery.">
  <style>
    :root{
      --bg:#07060a;
      --glass:rgba(255,255,255,.06);
      --glass-dark:rgba(0,0,0,.28);
      --border:rgba(255,255,255,.14);
      --text:rgba(255,255,255,.92);
      --muted:rgba(255,255,255,.70);
      --hot:#ff5b3d;
      --warm:#ffb04b;
      --shadow:0 22px 70px rgba(0,0,0,.55);
      --shadow2:0 14px 40px rgba(0,0,0,.42);
      --radius-xl:24px;
      --radius-lg:18px;
      --radius-pill:999px;
      --font:ui-sans-serif,system-ui,-apple-system,Segoe UI,Roboto,Arial,sans-serif;
    }

    *{box-sizing:border-box}
    html{scroll-behavior:smooth}
    body{
      margin:0;
      font-family:var(--font);
      color:var(--text);
      background:
        radial-gradient(1400px 800px at 20% -10%, rgba(255,91,61,.14), transparent 55%),
        radial-gradient(1200px 700px at 90% 0%, rgba(255,176,75,.10), transparent 55%),
        radial-gradient(1000px 700px at 50% 90%, rgba(255,255,255,.06), transparent 60%),
        var(--bg);
      padding-bottom:92px;
    }

    a{color:inherit}
    img{display:block;max-width:100%}
    .wrap{max-width:1140px;margin:0 auto;padding:18px 16px 54px}

    .hero-mini{
      position:relative;
      overflow:hidden;
      border:1px solid var(--border);
      border-radius:28px;
      background:rgba(0,0,0,.18);
      box-shadow:var(--shadow2);
      margin-bottom:16px;
    }

    .hero-mini::before{
      content:"";
      position:absolute;
      inset:0;
      background:
        radial-gradient(820px 420px at 18% 0%, rgba(255,180,90,0.14), transparent 66%),
        radial-gradient(840px 460px at 88% 0%, rgba(255,80,60,0.11), transparent 62%),
        radial-gradient(980px 560px at 50% 110%, rgba(255,60,140,0.09), transparent 60%),
        linear-gradient(180deg, rgba(6,7,10,0.22), rgba(6,7,10,0.80));
      pointer-events:none;
    }

    .hero-mini-inner{
      position:relative;
      z-index:1;
      max-width:1100px;
      margin:0 auto;
      padding:14px 16px 16px;
      text-align:center;
    }

    .hero-kicker{
      color:rgba(255,255,255,.72);
      font-weight:900;
      font-size:10px;
      text-transform:uppercase;
      letter-spacing:.22px;
    }

    .hero-title{
      margin:6px 0 4px;
      font-weight:950;
      letter-spacing:-.03em;
      line-height:1.05;
      font-size:clamp(20px,2.3vw,30px);
    }

    .hero-sub{
      margin:0;
      color:rgba(255,255,255,.78);
      font-size:13px;
      line-height:1.42;
    }

    .hero-actions{
      display:flex;
      gap:8px;
      flex-wrap:wrap;
      justify-content:center;
      margin-top:10px;
    }

    .btn{
      text-decoration:none;
      display:inline-flex;
      align-items:center;
      justify-content:center;
      padding:10px 14px;
      border-radius:999px;
      font-weight:900;
      font-size:13px;
      color:var(--text);
      border:1px solid var(--border);
      background:rgba(0,0,0,.26);
      box-shadow:0 12px 34px rgba(0,0,0,.35);
      transition:transform .14s ease, box-shadow .14s ease, background .14s ease;
    }

    .btn:hover{transform:translateY(-1px);box-shadow:0 18px 46px rgba(0,0,0,.45)}
    .btn-primary{
      border-color:transparent;
      background:linear-gradient(135deg,var(--hot),var(--warm));
      color:#1a0d0b;
    }

    .menu-strip{
      position:relative;
      margin-top:12px;
      overflow:hidden;
      border-radius:28px;
      border:1px solid var(--border);
      background:rgba(0,0,0,.18);
      box-shadow:var(--shadow2);
      padding:8px 0;
    }

    .menu-track{
      display:flex;
      gap:10px;
      width:max-content;
      padding:0 12px;
      will-change:transform;
      user-select:none;
      touch-action:pan-x;
    }

    .menu-card{
      flex:0 0 auto;
      width:190px;
      border-radius:20px;
      border:1px solid var(--border);
      background:rgba(6,7,10,.44);
      box-shadow:0 10px 24px rgba(0,0,0,.50), inset 0 1px 0 rgba(255,255,255,.08);
      overflow:hidden;
      cursor:pointer;
    }

    .menu-card-top{
      padding:10px 11px 8px;
      display:flex;
      justify-content:space-between;
      align-items:center;
      gap:10px;
    }

    .menu-card-name{
      font-size:12px;
      font-weight:950;
      line-height:1.1;
    }

    .menu-card-tag{
      font-size:10px;
      white-space:nowrap;
      color:rgba(255,255,255,.72);
      font-weight:900;
    }

    .menu-heat{
      height:4px;
      background:linear-gradient(90deg, rgba(255,80,60,0), rgba(255,140,80,.75), rgba(255,60,140,.65), rgba(255,80,60,0));
    }

    .home{
      position:relative;
      overflow:hidden;
    }

    .backdrop{position:absolute;inset:0;pointer-events:none}
    .smoke{
      position:absolute; inset:-20%;
      background:
        radial-gradient(700px 420px at 20% 25%, rgba(255,255,255,.06), transparent 60%),
        radial-gradient(700px 420px at 70% 35%, rgba(255,255,255,.04), transparent 62%),
        radial-gradient(900px 540px at 50% 80%, rgba(255,91,61,.06), transparent 70%);
      filter:blur(16px);
      transform:rotate(-6deg);
      opacity:.9;
    }
    .glow{
      position:absolute; inset:-10%;
      background:conic-gradient(from 120deg, rgba(255,91,61,.10), rgba(255,176,75,.08), rgba(255,255,255,.06), rgba(255,91,61,.10));
      filter:blur(40px);
      opacity:.55;
    }

    .hero{
      display:grid;
      grid-template-columns:1.3fr .7fr;
      gap:16px;
      align-items:stretch;
    }

    .hero-card,
    .panel,
    .fb-panel{
      border:1px solid var(--border);
      border-radius:var(--radius-xl);
      background:linear-gradient(to bottom, rgba(255,255,255,.08), rgba(255,255,255,.05));
      box-shadow:var(--shadow);
      backdrop-filter:blur(12px);
      -webkit-backdrop-filter:blur(12px);
    }

    .hero-card{
      padding:22px 20px;
      position:relative;
      overflow:hidden;
    }

    .hero-card::before{
      content:"";
      position:absolute; inset:0;
      background:
        radial-gradient(900px 260px at 15% 0%, rgba(255,91,61,.14), transparent 62%),
        radial-gradient(900px 260px at 85% 10%, rgba(255,176,75,.10), transparent 62%);
      pointer-events:none;
    }

    .hero-card > *{position:relative;z-index:1}

    .kicker{
      display:inline-block;
      padding:7px 12px;
      border-radius:999px;
      border:1px solid rgba(255,255,255,.18);
      background:rgba(0,0,0,.22);
      font-weight:750;
      color:var(--muted);
      font-size:13px;
    }

    h1{
      margin:12px 0 6px;
      font-size:clamp(28px,4vw,44px);
      letter-spacing:-.04em;
      line-height:1.02;
      font-weight:950;
    }

    .sub{
      margin:0 0 14px;
      color:var(--muted);
      font-weight:700;
      font-size:clamp(14px,1.6vw,16px);
      line-height:1.35;
    }

    .cta-row{
      display:flex;
      flex-wrap:wrap;
      gap:10px;
      margin:12px 0;
    }

    .facts{
      display:flex;
      flex-wrap:wrap;
      gap:8px;
      margin-top:10px;
    }

    .pill{
      display:inline-flex;
      align-items:center;
      gap:10px;
      padding:9px 12px;
      border-radius:999px;
      border:1px solid var(--border);
      background:rgba(255,255,255,.06);
      font-weight:800;
      color:rgba(255,255,255,.82);
      font-size:13px;
    }

    .dot{width:9px;height:9px;border-radius:99px;background:var(--hot);box-shadow:0 0 0 4px rgba(255,91,61,.18)}
    .dot2{background:var(--warm);box-shadow:0 0 0 4px rgba(255,176,75,.16)}
    .dot3{background:rgba(255,255,255,.72);box-shadow:0 0 0 4px rgba(255,255,255,.10)}

    .sigil{
      position:relative;
      width:240px;
      height:240px;
      border-radius:50%;
      display:grid;
      place-items:center;
      justify-self:center;
      border:1px solid rgba(255,255,255,.18);
      background:
        radial-gradient(circle at 30% 20%, rgba(255,176,75,.12), transparent 55%),
        radial-gradient(circle at 70% 80%, rgba(255,91,61,.14), transparent 55%),
        rgba(0,0,0,.34);
      box-shadow:0 30px 80px rgba(0,0,0,.62), inset 0 0 0 1px rgba(255,255,255,.08);
      overflow:hidden;
    }

    .sigil::before{
      content:"";
      position:absolute;
      inset:-40%;
      background:conic-gradient(from 0deg, rgba(255,91,61,.16), rgba(255,176,75,.14), rgba(255,255,255,.06), rgba(255,91,61,.16));
      filter:blur(42px);
      opacity:.6;
      animation:spin 18s linear infinite;
    }

    @keyframes spin{to{transform:rotate(360deg)}}

    .sigil-ring{
      position:absolute;
      inset:20px;
      border-radius:50%;
      border:1px solid rgba(255,255,255,.16);
      box-shadow:inset 0 0 28px rgba(255,255,255,.06), 0 0 40px rgba(255,91,61,.18);
      z-index:1;
    }

    .sigil-core{
      position:absolute;
      width:140px;
      height:140px;
      border-radius:50%;
      background:radial-gradient(circle at 30% 20%, rgba(255,255,255,.10), transparent 60%), rgba(0,0,0,.28);
      border:1px solid rgba(255,255,255,.12);
      box-shadow:inset 0 0 40px rgba(0,0,0,.55);
      z-index:2;
    }

    .sigil-logo{
      position:relative;
      z-index:3;
      width:96px;
      height:96px;
      border-radius:50%;
      object-fit:cover;
      border:2px solid rgba(255,255,255,.22);
      box-shadow:0 20px 48px rgba(0,0,0,.6), inset 0 0 0 1px rgba(255,255,255,.12);
    }

    .sigil-text{
      position:absolute;
      bottom:14px;
      z-index:4;
      font-weight:900;
      letter-spacing:.30em;
      font-size:11px;
      color:rgba(255,255,255,.74);
    }

    .nav-grid{
      display:grid;
      grid-template-columns:repeat(4, minmax(0,1fr));
      gap:12px;
      margin:14px 0;
    }

    .nav-card{
      display:block;
      text-decoration:none;
      color:var(--text);
      border:1px solid var(--border);
      background:var(--glass);
      border-radius:var(--radius-lg);
      padding:14px;
      box-shadow:var(--shadow2);
      transition:transform .14s ease, background .14s ease;
    }

    .nav-card:hover{transform:translateY(-2px);background:rgba(255,255,255,.08)}
    .nav-icon{font-size:22px}
    .nav-title{margin-top:8px;font-weight:950;font-size:16px}
    .nav-desc{margin-top:6px;color:var(--muted);font-size:13px;line-height:1.35;font-weight:700}

    .split{
      display:grid;
      grid-template-columns:1.2fr .8fr;
      gap:12px;
      margin-top:12px;
    }

    .panel{padding:18px;box-shadow:var(--shadow2)}
    h2{
      margin:0 0 8px;
      font-weight:950;
      letter-spacing:-.03em;
      font-size:clamp(18px,2.5vw,22px);
    }

    .panel p{
      margin:0;
      color:var(--muted);
      font-weight:700;
      font-size:14px;
      line-height:1.45;
    }

    .feature-row{
      margin-top:14px;
      display:grid;
      grid-template-columns:1fr 1fr;
      gap:10px;
    }

    .feature{
      border-radius:18px;
      border:1px solid var(--border);
      background:rgba(0,0,0,.20);
      padding:12px;
    }

    .feature-top{display:flex;gap:8px;flex-wrap:wrap;margin-bottom:8px}
    .chip{
      font-size:12px;
      font-weight:900;
      letter-spacing:.08em;
      text-transform:uppercase;
      padding:6px 10px;
      border-radius:999px;
      border:1px solid var(--border);
      background:rgba(255,255,255,.06);
      color:rgba(255,255,255,.80);
    }

    .feature-text{color:rgba(255,255,255,.72);font-weight:700;font-size:13px;line-height:1.4}

    .info-top{
      display:flex;
      align-items:flex-start;
      justify-content:space-between;
      gap:10px;
    }

    .mini{color:rgba(255,255,255,.66);font-weight:900;font-size:12px;letter-spacing:.18em;text-transform:uppercase}
    .strong{margin-top:6px;font-weight:900;font-size:14px}
    .link{display:inline-block;margin-top:8px;color:rgba(255,255,255,.82);font-weight:900;text-decoration:none}
    .link:hover{text-decoration:underline}

    .badge{
      padding:8px 10px;
      border-radius:999px;
      font-weight:950;
      font-size:12px;
      letter-spacing:.18em;
      text-transform:uppercase;
      background:linear-gradient(135deg, rgba(255,91,61,.20), rgba(255,176,75,.18));
      border:1px solid rgba(255,255,255,.16);
      white-space:nowrap;
    }

    .hours-box{
      margin-top:14px;
      border-radius:18px;
      border:1px solid var(--border);
      overflow:hidden;
    }

    .hour-row{
      display:flex;
      justify-content:space-between;
      gap:10px;
      padding:10px 12px;
      background:rgba(0,0,0,.22);
      border-top:1px solid rgba(255,255,255,.10);
      font-weight:800;
      color:rgba(255,255,255,.84);
      font-size:13px;
    }

    .hour-row:first-child{border-top:none}

    .call-box{
      margin-top:14px;
      padding:12px;
      border-radius:18px;
      border:1px solid var(--border);
      background:rgba(0,0,0,.22);
    }

    .call{
      display:inline-block;
      margin-top:6px;
      font-weight:950;
      font-size:18px;
      text-decoration:none;
    }

    .call-note{
      margin-top:8px;
      color:rgba(255,255,255,.68);
      font-weight:700;
      font-size:13px;
      line-height:1.35;
    }

    .fb-wrap{margin-top:14px}
    .fb-panel{
      padding:16px;
      position:relative;
      overflow:hidden;
      box-shadow:var(--shadow2);
    }

    .fb-panel::before{
      content:"";
      position:absolute;
      inset:0;
      background:
        radial-gradient(900px 260px at 12% 0%, rgba(255,91,61,.12), transparent 62%),
        radial-gradient(900px 260px at 88% 10%, rgba(255,176,75,.10), transparent 62%);
      pointer-events:none;
    }

    .fb-panel > *{position:relative;z-index:1}

    .fb-top{
      display:flex;
      justify-content:space-between;
      align-items:flex-start;
      gap:12px;
      margin-bottom:12px;
    }

    .fb-title{margin-top:6px;font-weight:950;font-size:18px}
    .fb-sub{margin-top:6px;color:var(--muted);font-size:13px;line-height:1.35;font-weight:750;max-width:560px}

    .fb-grid{
      display:grid;
      grid-template-columns:1.2fr .8fr;
      gap:12px;
      align-items:stretch;
    }

    .fb-embed,
    .fb-side{
      border-radius:18px;
      border:1px solid var(--border);
      background:rgba(0,0,0,.22);
      box-shadow:inset 0 0 0 1px rgba(255,255,255,.06);
    }

    .fb-embed{overflow:hidden;min-height:520px}
    .fb-embed iframe{width:100%;height:520px;border:0;display:block}

    .fb-side{
      padding:14px;
      display:flex;
      flex-direction:column;
      gap:10px;
    }

    .fb-side-icon{
      width:44px;height:44px;border-radius:14px;
      display:grid;place-items:center;
      background:linear-gradient(135deg, rgba(255,91,61,.22), rgba(255,176,75,.18));
      border:1px solid rgba(255,255,255,.16);
      box-shadow:0 18px 46px rgba(0,0,0,.35);
      font-size:20px;
    }

    .fb-side h3{margin:0;font-size:16px}
    .fb-side p{margin:0;color:var(--muted);font-size:13px;line-height:1.35;font-weight:750}
    .fb-pills{margin-top:auto;display:flex;flex-wrap:wrap;gap:8px}

    .marquee{
      margin-top:14px;
      border-radius:var(--radius-xl);
      border:1px solid var(--border);
      background:rgba(255,255,255,.05);
      overflow:hidden;
      box-shadow:var(--shadow2);
    }

    .marquee-track{
      display:flex;
      gap:10px;
      padding:12px;
      width:max-content;
      animation:marquee 26s linear infinite;
    }

    @keyframes marquee{
      from{transform:translateX(0)}
      to{transform:translateX(-50%)}
    }

    .photo{
      width:260px;
      aspect-ratio:4/3;
      border-radius:18px;
      overflow:hidden;
      border:1px solid var(--border);
      background:rgba(0,0,0,.25);
      flex:0 0 auto;
    }

    .photo img{
      width:100%;
      height:100%;
      object-fit:cover;
      transform:scale(1.02);
      filter:contrast(1.02) saturate(1.02);
    }

    .dock{
      position:fixed;
      left:50%;
      bottom:16px;
      transform:translateX(-50%);
      width:min(660px, calc(100vw - 26px));
      display:flex;
      justify-content:space-between;
      gap:10px;
      padding:10px;
      border-radius:999px;
      border:1px solid var(--border);
      background:rgba(6,7,10,.62);
      backdrop-filter:blur(18px);
      -webkit-backdrop-filter:blur(18px);
      box-shadow:0 18px 50px rgba(0,0,0,.62), inset 0 1px 0 rgba(255,255,255,.08);
      z-index:9999;
    }

    .dock-btn{
      text-decoration:none;
      color:rgba(255,255,255,.92);
      flex:1 1 0;
      min-width:0;
      display:flex;
      flex-direction:column;
      align-items:center;
      justify-content:center;
      gap:4px;
      border-radius:16px;
      border:1px solid rgba(255,255,255,.12);
      background:rgba(0,0,0,.36);
      padding:10px 8px;
      box-shadow:0 10px 22px rgba(0,0,0,.34), inset 0 1px 0 rgba(255,255,255,.08);
      transition:transform .14s ease, background .14s ease;
      cursor:pointer;
    }

    .dock-btn:hover{transform:translateY(-1px);background:rgba(0,0,0,.56)}
    .dock-cta{background:linear-gradient(90deg, rgba(255,120,70,.22), rgba(255,60,140,.16))}
    .dock-ic{font-size:16px;line-height:1}
    .dock-tx{font-size:11.5px;font-weight:900;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}

    .site-footer,.site-footer *{box-sizing:border-box}
    .site-footer{
      color:rgba(255,255,255,.92);
      padding:clamp(28px,3.5vw,52px) clamp(16px,3vw,28px) 18px;
      border-top:1px solid rgba(255,255,255,.12);
      text-align:center;
    }

    .footer-inner{
      max-width:1160px;
      margin:0 auto;
      display:grid;
      grid-template-columns:repeat(3,1fr);
      gap:clamp(24px,4vw,60px);
      justify-items:center;
    }

    .footer-col{
      display:flex;
      flex-direction:column;
      align-items:center;
      gap:10px;
    }

    .footer-title{margin:0 0 6px;font-size:1.12rem;font-weight:650}
    .footer-text{margin:0 0 6px;line-height:1.6;color:rgba(255,255,255,.82)}
    .footer-link,.social-link{
      display:inline-flex;align-items:center;gap:8px;
      color:rgba(255,255,255,.9);text-decoration:none;
      border-bottom:1px solid rgba(255,255,255,.18);padding-bottom:2px;
    }

    .hours{
      width:100%;max-width:360px;margin:6px auto 10px;
      border:1px solid rgba(255,255,255,.14);
      border-radius:14px;padding:16px;
      box-shadow:0 10px 40px rgba(0,0,0,.18);
    }

    .hours-title{margin:0 0 14px;font-weight:700}
    .hours-list{display:grid;gap:14px}
    .hours-row{display:flex;flex-direction:column;gap:4px}
    .hours-row .day{font-weight:600}
    .hours-row .time{font-variant-numeric:tabular-nums;opacity:.95}
    .crawfish-hours{font-size:.9em;opacity:.85}
    .contact-block{display:flex;flex-direction:column;align-items:center;gap:6px}
    .icon{
      display:inline-flex;width:28px;height:28px;align-items:center;justify-content:center;
      border-radius:999px;border:1px solid rgba(255,255,255,.22);
    }

    .footer-bottom{
      max-width:1160px;
      margin:28px auto 0;
      padding-top:16px;
      border-top:1px solid rgba(255,255,255,.12);
      display:flex;
      flex-direction:column;
      align-items:center;
      gap:6px;
    }

    .footer-meta{margin:0;font-size:.95rem;color:rgba(255,255,255,.72)}
    .footer-credit{margin:0;font-size:.85rem;color:rgba(255,255,255,.55)}
    .footer-credit strong{font-weight:600;color:rgba(255,255,255,.75)}
    .credit-name{color:rgba(255,255,255,.65)}

    @media (max-width:900px){
      .hero{grid-template-columns:1fr}
      .split{grid-template-columns:1fr}
      .nav-grid{grid-template-columns:repeat(2, minmax(0,1fr))}
      .fb-top{flex-direction:column}
      .fb-grid{grid-template-columns:1fr}
      .footer-inner{grid-template-columns:1fr}
      .sigil{width:200px;height:200px}
      .sigil-core{width:118px;height:118px}
      .sigil-logo{width:84px;height:84px}
    }

    @media (max-width:720px){
