  <script>
    (function(){
      const items = [
        "Smothered Pork Chops",
        "Fried Chicken",
        "Red Beans & Rice",
        "Mac & Cheese",
        "Cabbage",
        "Cornbread"
      ];

      const track = document.getElementById("menuTrack");
      const dateEl = document.getElementById("heroDate");
      const yearEl = document.getElementById("year");
      const shareBtn = document.getElementById("shareBtn");
      if (!track) return;

      const now = new Date();
      dateEl.textContent = now.toLocaleDateString("en-US", { weekday:"long", year:"numeric", month:"2-digit", day:"2-digit" });
      yearEl.textContent = now.getFullYear();

      function card(name){
        return `
          <div class="menu-card" tabindex="0" role="button" aria-label="Open menu for ${name}">
            <div class="menu-card-top">
              <div class="menu-card-name">${name}</div>
              <div class="menu-card-tag">Tap → Menu</div>
            </div>
            <div class="menu-heat" aria-hidden="true"></div>
          </div>
        `;
      }

      track.innerHTML = items.map(card).join("") + items.map(card).join("");

      function goMenu(){ window.location.href = "menu.html"; }

      track.querySelectorAll(".menu-card").forEach(function(el){
        el.addEventListener("click", goMenu);
        el.addEventListener("keydown", function(e){
          if (e.key === "Enter" || e.key === " ") {
            e.preventDefault();
            goMenu();
          }
        });
      });

      let x = 0;
      let w = 0;
      let isHover = false;
      let isDown = false;
      let startX = 0;
      let startOffset = 0;
      const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

      function recalc(){ w = track.scrollWidth / 2; }
      function setTransform(){ track.style.transform = "translate3d(" + (-x) + "px,0,0)"; }

      recalc();
      window.addEventListener("resize", recalc);

      track.addEventListener("mouseenter", function(){ isHover = true; });
      track.addEventListener("mouseleave", function(){ isHover = false; });

      track.addEventListener("pointerdown", function(e){
        isDown = true;
        try { track.setPointerCapture(e.pointerId); } catch(err){}
        startX = e.clientX;
        startOffset = x;
      });

      track.addEventListener("pointermove", function(e){
        if (!isDown) return;
        const dx = e.clientX - startX;
        x = startOffset - dx;
        if (w > 0) x = ((x % w) + w) % w;
        setTransform();
      });

      function stopDrag(){ isDown = false; }
      track.addEventListener("pointerup", stopDrag);
      track.addEventListener("pointercancel", stopDrag);

      function tick(){
        if (!reduceMotion && !isHover && !isDown) {
          x += 1.1;
          if (w > 0 && x >= w) x -= w;
          setTransform();
        }
        requestAnimationFrame(tick);
      }
      tick();

      if (shareBtn) {
        shareBtn.addEventListener("click", async function(){
          const data = {
            title: document.title,
            text: "Take a look at this page",
            url: window.location.href
          };

          try {
            if (navigator.share) {
              await navigator.share(data);
              return;
            }

            if (navigator.clipboard && navigator.clipboard.writeText) {
              await navigator.clipboard.writeText(window.location.href);
              const label = shareBtn.querySelector(".dock-tx");
              const oldText = label ? label.textContent : "";
              if (label) label.textContent = "Copied";
              setTimeout(function(){
                if (label) label.textContent = oldText;
              }, 1800);
            }
          } catch (err) {
            console.log("Share failed", err);
          }
        });
      }
    })();
  </script>
